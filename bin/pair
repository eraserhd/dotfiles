#!/usr/bin/env bash

set -eo pipefail

command="$1"
if [[ -z $command ]]; then
    command=on
fi

case "$command" in
  on)  mode=1920x1080;;
  off) mode=3840x2160;;
  *)
      printf 'Unknown command %s\n' "$command" >&2
      exit 1
    ;;
esac

exec xrandr --output DP-0 --mode "$mode" --right-of HDMI-0
