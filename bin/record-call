#!/usr/bin/env nix-shell
#!nix-shell -i bash -p pipewire pulseaudio ffmpeg

# record-call — Record a Zoom/browser call via PipeWire on NixOS
# Records AirPods output (remote audio) and C920 mic as separate tracks,
# then merges them with ffmpeg.
# Usage: record-call [basename]

set -euo pipefail

# ── Configuration ────────────────────────────────────────────────────────────

readonly AIRPODS_SINK="bluez_output.90_9C_4A_E6_44_B2"  # PulseAudio compat name
readonly C920_MIC_PATTERN="HD_Pro_Webcam_C920"           # partial match, resolved at runtime

readonly CALLS_DIR="$HOME/src/ALL/calls"
readonly BASENAME="${1:-$(date +%Y%m%d-%H%M%S)}"
readonly OUT_REMOTE="${CALLS_DIR}/${BASENAME}-remote.wav"
readonly OUT_MIC="${CALLS_DIR}/${BASENAME}-mic.wav"
readonly OUT_MIXED="${CALLS_DIR}/${BASENAME}.wav"

# ── Helpers ──────────────────────────────────────────────────────────────────

die() { echo "ERROR: $*" >&2; exit 1; }

resolve_input_node() {
    pw-cli list-objects Node 2>/dev/null \
        | grep 'node\.name' \
        | sed 's/.*node\.name = "\([^"]*\)".*/\1/' \
        | grep "$1" \
        | grep -E 'input|source|capture' \
        | head -1
}

# ── Preflight checks ─────────────────────────────────────────────────────────

C920_NODE=$(resolve_input_node "$C920_MIC_PATTERN")
[[ -n "$C920_NODE" ]] \
    || die "C920 mic node not found (is the webcam plugged in?)"
echo "C920 mic node: ${C920_NODE}"

pactl list sources short | grep -q "${AIRPODS_SINK}" \
    || die "AirPods monitor '${AIRPODS_SINK}.monitor' not found — are they connected?"

mkdir -p "$CALLS_DIR"

# ── Record ───────────────────────────────────────────────────────────────────

REMOTE_PID=""
MIC_PID=""
CLEANED_UP=0

cleanup() {
    [[ $CLEANED_UP -eq 1 ]] && return
    CLEANED_UP=1

    echo ""
    echo "Stopping recording..."
    [[ -n "$REMOTE_PID" ]] && kill "$REMOTE_PID" 2>/dev/null || true
    [[ -n "$MIC_PID"    ]] && kill "$MIC_PID"    2>/dev/null || true
    wait 2>/dev/null || true

    echo "Merging tracks..."
    ffmpeg -y -loglevel warning \
        -i "$OUT_REMOTE" \
        -i "$OUT_MIC" \
        -filter_complex amix=inputs=2:normalize=0 \
        "$OUT_MIXED" \
        && echo "Mixed:  ${OUT_MIXED}" \
        && rm "$OUT_REMOTE" "$OUT_MIC" \
        || {
            echo "Merge failed — tracks saved separately:"
            echo "  Remote: ${OUT_REMOTE}"
            echo "  Mic:    ${OUT_MIC}"
        }
}
trap cleanup EXIT INT TERM

echo "Recording to: ${OUT_MIXED}"
echo "Press Ctrl-C to stop."
echo ""

parec --device="${AIRPODS_SINK}.monitor" \
      --format=s16le --rate=48000 --channels=2 \
      --file-format=wav "$OUT_REMOTE" &
REMOTE_PID=$!

parec --device="${C920_NODE}" \
      --format=s16le --rate=48000 --channels=2 \
      --file-format=wav "$OUT_MIC" &
MIC_PID=$!

wait $REMOTE_PID $MIC_PID
